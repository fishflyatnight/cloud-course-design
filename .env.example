# Copy this file to .env, then replace placeholders locally.
# Never commit .env, AK/SK, SWR login tokens, or kubeconfig files.

STUDENT_ID="[STUDENT_ID]"
STUDENT_NAME="[STUDENT_NAME]"

REGION="[REGION]"
SWR_ORG="[SWR_ORG]"
SWR_AK="[SWR_AK]"
SWR_SK="[SWR_SK]"
SWR_LOGIN_PASSWORD="[SWR_LOGIN_PASSWORD]"
SWR_IMAGE_BACKEND="[SWR_IMAGE_BACKEND]"
SWR_IMAGE_FRONTEND="[SWR_IMAGE_FRONTEND]"
SWR_IMAGE_SPARK="[SWR_IMAGE_SPARK]"

CCE_CLUSTER_NAME="[CCE_CLUSTER_NAME]"
KUBECONFIG_PATH="[KUBECONFIG_PATH]"
OBS_BUCKET="[OBS_BUCKET]"
OBS_DATA_PATH="[OBS_DATA_PATH]"
ELB_IP="[ELB_IP]"
REDIS_PASSWORD="[REDIS_PASSWORD]"

# The online default may fail on restricted networks. The teacher-provided
# pyspark-v9.tar can be loaded and its resulting image tag used instead.
SPARK_BASE_IMAGE="apache/spark-py:v3.4.0"

